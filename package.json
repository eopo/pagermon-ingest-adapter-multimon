{
  "name": "pagermon-ingest-multimon",
  "version": "1.3.0",
  "description": "PagerMon multimon adapter image and adapter implementation",
  "type": "module",
  "main": "index.js",
  "scripts": {
    "start": "node index.js",
    "test": "vitest run",
    "test:unit": "vitest run test/unit",
    "test:integration": "vitest run test/integration",
    "test:watch": "vitest",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"**/*.{js,mjs,json,md}\"",
    "format:check": "prettier --check \"**/*.{js,mjs,json,md}\"",
    "check": "npm run format:check && npm run lint",
    "postinstall": "[ -z \"$CI\" ] && lefthook install || true"
  },
  "lint-staged": {
    "*.{js,mjs}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md}": [
      "prettier --write"
    ]
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/eopo/pagermon-ingest-adapter-multimon"
  },
  "bugs": {
    "url": "https://github.com/eopo/pagermon-ingest-adapter-multimon/issues"
  },
  "homepage": "https://github.com/eopo/pagermon-ingest-adapter-multimon",
  "license": "GPL-2.0-or-later",
  "engines": {
    "node": ">=22.0.0",
    "npm": ">=9.0"
  },
  "dependencies": {
    "@pagermon/ingest-core": "1.2.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.4.3",
    "@commitlint/config-conventional": "^20.4.3",
    "@evilmartians/lefthook": "^2.1.3",
    "@vitest/coverage-v8": "^2.1.9",
    "eslint": "^9.16.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.2.1",
    "globals": "^15.14.0",
    "lint-staged": "^16.3.2",
    "prettier": "^3.4.2",
    "vitest": "^2.1.8"
  }
}
