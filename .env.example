# Pagermon Ingest Service configuration
#
# Prefixes:
# - Core:    INGEST_CORE__*
# - Adapter: INGEST_ADAPTER__*

# -----------------------------------------------------------------------------
# Core configuration
# -----------------------------------------------------------------------------

INGEST_CORE__LABEL=pagermon-ingest
INGEST_CORE__API_URL=http://pagermon:3000
INGEST_CORE__API_NAME=pm-prod-a
INGEST_CORE__API_KEY=your_api_key_here
# Optional alternative for secrets:
# INGEST_CORE__API_KEY_FILE=/run/secrets/pagermon_api_key
# Do not set KEY and KEY_FILE for the same target at the same time.

# Optional additional targets
# INGEST_CORE__API_* is an alias to INGEST_CORE__API_1_*, so do not define both at the same time.
# INGEST_CORE__API_1_NAME=pm-prod-a
# INGEST_CORE__API_1_URL=http://pagermon-a:3000
# INGEST_CORE__API_1_KEY=key_a
# INGEST_CORE__API_2_NAME=pm-prod-b
# INGEST_CORE__API_2_URL=http://pagermon-b:3000
# INGEST_CORE__API_2_KEY_FILE=/run/secrets/pagermon_api2_key

INGEST_CORE__REDIS_URL=redis://redis:6379
# Redis persistence (AOF) is configured in compose.yml for BullMQ durability.
INGEST_CORE__ENABLE_DLQ=true
INGEST_CORE__HEALTH_CHECK_INTERVAL=10000
INGEST_CORE__HEALTH_UNHEALTHY_THRESHOLD=3

# -----------------------------------------------------------------------------
# Multimon adapter configuration
# -----------------------------------------------------------------------------

# Required for built-in adapter
INGEST_ADAPTER__FREQUENCIES=163000000
INGEST_ADAPTER__PROTOCOLS=POCSAG512

# Optional for built-in adapter
INGEST_ADAPTER__GAIN=30
INGEST_ADAPTER__SQUELCH=2.5
INGEST_ADAPTER__PPM=0
INGEST_ADAPTER__DEVICE=0
INGEST_ADAPTER__CHARSET=UTF-8
# INGEST_ADAPTER__VERBOSITY_LEVEL=1
# Optional decoder output hint for multimon-ng (`-f`)
# INGEST_ADAPTER__FORMAT=alpha
# Decoder output hint for multimon-ng (`-f`), not the final PagerMon message format.
# Final message format is resolved in ingest-core (format -> metadata.format -> fallback inference).
# Optional passthrough for advanced flags not explicitly modeled
# INGEST_ADAPTER__RTL_FM_EXTRA_ARGS=-M fm -s 24000
# INGEST_ADAPTER__MULTIMON_EXTRA_ARGS=--label ingest-a

# -----------------------------------------------------------------------------
# Metrics & Observability (optional)
# -----------------------------------------------------------------------------

# Enable Prometheus metrics endpoint
# INGEST_CORE__METRICS_ENABLED=true
# INGEST_CORE__METRICS_PORT=9464
# INGEST_CORE__METRICS_HOST=0.0.0.0
# INGEST_CORE__METRICS_PATH=/metrics
