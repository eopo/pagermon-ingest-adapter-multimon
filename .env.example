# Pagermon Ingest Service configuration
#
# Prefixes:
# - Core:    INGEST_CORE__*
# - Adapter: INGEST_ADAPTER__*

# -----------------------------------------------------------------------------
# Core configuration
# -----------------------------------------------------------------------------

INGEST_CORE__LABEL=pagermon-ingest
INGEST_CORE__API_URL=http://pagermon:3000
INGEST_CORE__API_KEY=your_api_key_here
INGEST_CORE__REDIS_URL=redis://redis:6379
# Redis persistence (AOF) is configured in compose.yml for BullMQ durability.
INGEST_CORE__ENABLE_DLQ=true
INGEST_CORE__HEALTH_CHECK_INTERVAL=10000
INGEST_CORE__HEALTH_UNHEALTHY_THRESHOLD=3

# -----------------------------------------------------------------------------
# Multimon adapter configuration
# -----------------------------------------------------------------------------

# Required for built-in adapter
INGEST_ADAPTER__FREQUENCIES=163000000
INGEST_ADAPTER__PROTOCOLS=POCSAG512

# Optional for built-in adapter
INGEST_ADAPTER__GAIN=30
INGEST_ADAPTER__SQUELCH=2.5
INGEST_ADAPTER__PPM=0
INGEST_ADAPTER__DEVICE=0
INGEST_ADAPTER__CHARSET=UTF-8
INGEST_ADAPTER__FORMAT=alpha
# Optional passthrough for advanced flags not explicitly modeled
# INGEST_ADAPTER__RTL_FM_EXTRA_ARGS=-M fm -s 24000
# INGEST_ADAPTER__MULTIMON_EXTRA_ARGS=--label ingest-a
